# Database (Railway provides this automatically when you add a Postgres service)
DATABASE_URL="postgresql://user:password@host:5432/tahlk"

# Security — generate each with: openssl rand -hex 64
JWT_SECRET="replace-me"
REFRESH_SECRET="replace-me"
COOKIE_SECRET="replace-me"

# App
NODE_ENV="production"
PORT=3001
LOG_LEVEL="info"

# CORS — comma-separated; Tauri uses tauri://localhost in prod
ALLOWED_ORIGINS="tauri://localhost,https://app.tahlkscribe.com"

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # from: stripe listen --print-secret (dev) or Dashboard (prod)

# Stripe Price IDs — create monthly recurring prices in the Stripe dashboard
# Solo $599/mo · Pro $1,699/mo · Firm $3,499/mo
STRIPE_PRICE_ID_SOLO="price_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_FIRM="price_..."

# Post-checkout redirect base (browser lands here after Stripe Checkout)
APP_URL="https://api.tahlkscribe.com"

# AWS S3 — PDF archival (HIPAA: enable bucket versioning + block all public access)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="tahlk-clinical-pdfs"

# Transactional email — get key from https://resend.com
RESEND_API_KEY="re_..."
EMAIL_FROM="Tahlk <no-reply@tahlkscribe.com>"

# Beta access — comma-separated codes; leave blank to allow open registration
BETA_CODES=""

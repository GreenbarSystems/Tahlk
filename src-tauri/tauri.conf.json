{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tahlk",
  "version": "0.1.0",
  "identifier": "com.tahlk.app",

  "build": {
    "beforeDevCommand": "npm run dev:solo",
    "beforeBuildCommand": "npm run build:solo",
    "frontendDist": "../dist-solo",
    "devUrl": "http://localhost:5173/solo.html"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tahlk",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: http://tauri.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; form-action 'self'; base-uri 'self'; frame-ancestors 'none';"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Medical",
    "copyright": "© Tahlk",
    "longDescription": "Ambient AI scribe for independent behavioral health and psychiatry practices. Listens to patient encounters, generates structured clinical notes, and requires physician sign-off before finalization. Audio stays on your device.",
    "shortDescription": "Privacy-first AI scribe for behavioral health",
    "externalBin": ["binaries/whisper-cpp"],
    "resources": {
      "resources/ggml-base.en.bin": "ggml-base.en.bin",
      "binaries/whisper.dll": "whisper.dll",
      "binaries/ggml.dll": "ggml.dll",
      "binaries/ggml-base.dll": "ggml-base.dll",
      "binaries/ggml-cpu-alderlake.dll": "ggml-cpu-alderlake.dll",
      "binaries/ggml-cpu-cannonlake.dll": "ggml-cpu-cannonlake.dll",
      "binaries/ggml-cpu-cascadelake.dll": "ggml-cpu-cascadelake.dll",
      "binaries/ggml-cpu-haswell.dll": "ggml-cpu-haswell.dll",
      "binaries/ggml-cpu-icelake.dll": "ggml-cpu-icelake.dll",
      "binaries/ggml-cpu-sandybridge.dll": "ggml-cpu-sandybridge.dll",
      "binaries/ggml-cpu-skylakex.dll": "ggml-cpu-skylakex.dll",
      "binaries/ggml-cpu-sse42.dll": "ggml-cpu-sse42.dll",
      "binaries/ggml-cpu-x64.dll": "ggml-cpu-x64.dll"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  }
}
